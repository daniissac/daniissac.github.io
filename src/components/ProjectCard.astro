---
import { ArrowUpRight, GitBranch as Github } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { data } = project;
---

<article class:list={["project-card", { compact }]}>
  <div class="project-card-topline">
    <span class:list={["status-label", `status-${data.status}`]}>{data.status}</span>
    <a class="card-icon-link" href={data.repositoryUrl} target="_blank" rel="noopener noreferrer" aria-label={`View ${data.title} source on GitHub`} title="View source">
      <Github size={18} aria-hidden="true" />
    </a>
  </div>
  <div>
    <h3><a href={`/projects/${project.id}/`}>{data.title}</a></h3>
    <p>{data.description}</p>
  </div>
  <ul class="tag-list" aria-label={`${data.title} technologies`}>
    {data.tags.slice(0, compact ? 3 : 5).map((tag) => <li>{tag}</li>)}
  </ul>
  <a class="text-link" href={`/projects/${project.id}/`}>
    View project <ArrowUpRight size={16} aria-hidden="true" />
  </a>
</article>
