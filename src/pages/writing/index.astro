---
import { getCollection } from "astro:content";
import { ArrowRight, ArrowUpRight, Rss } from "@lucide/astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const writing = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "numeric" }).format(date);
---

<BaseLayout
  title="Writing | Dani Issac"
  description="Technical writing about network behavior, troubleshooting, observability, automation, and the design of useful learning experiences."
>
  <header class="page-hero shell reading-shell">
    <p class="eyebrow">Writing</p>
    <h1>Networks, explained from behavior outward.</h1>
    <p>
      Practical mental models for network behavior, observability, troubleshooting, and building technical tools.
      Long-form work lives here; shorter versions travel through LinkedIn.
    </p>
    <a class="text-link" href="/rss.xml"><Rss size={16} aria-hidden="true" /> Subscribe with RSS</a>
  </header>

  <section class="content-section">
    <div class="shell reading-shell">
      {writing.length > 0 ? (
        <div class="writing-list">
          {writing.map((post) => (
            <article class="writing-list-item">
              <p class="article-meta"><time datetime={post.data.publishedDate.toISOString()}>{formatDate(post.data.publishedDate)}</time></p>
              <h2><a href={`/writing/${post.id}/`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <ul class="tag-list" aria-label={`${post.data.title} topics`}>
                {post.data.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <a class="text-link" href={`/writing/${post.id}/`}>Read article <ArrowRight size={16} aria-hidden="true" /></a>
            </article>
          ))}
        </div>
      ) : (
        <div class="writing-empty writing-empty-page">
          <div>
            <p class="eyebrow">First article in progress</p>
            <h2>What happens when you open a website?</h2>
          </div>
          <p>
            A companion to Internet in Motion is being developed as the first canonical article. Until then, the
            complete interactive journey is ready to explore.
          </p>
          <a class="button button-primary" href="/internet-in-motion/">Explore Internet in Motion <ArrowUpRight size={17} aria-hidden="true" /></a>
        </div>
      )}
    </div>
  </section>

  <section class="content-section pillars-section">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Editorial focus</p>
        <h2>Three connected lines of inquiry</h2>
      </div>
      <ol class="pillar-grid">
        <li>
          <span>01</span>
          <h3>How networks behave</h3>
          <p>DNS, routing, packets, transport, latency, bandwidth, loss, and web performance.</p>
        </li>
        <li>
          <span>02</span>
          <h3>Troubleshooting and observability</h3>
          <p>Diagnostic methods, synthetic monitoring, telemetry, and the limits of available evidence.</p>
        </li>
        <li>
          <span>03</span>
          <h3>Building technical tools</h3>
          <p>Automation, project decisions, learning design, and what changes after a prototype meets reality.</p>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>
