---
import {
  ArrowUpRight,
  BriefcaseBusiness as Linkedin,
  ExternalLink,
  GitBranch as Github,
} from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { CERTIFICATIONS, EXPERIENCE, SITE, SOCIAL, TECHNICAL_FOCUS } from "../config";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  url: SITE.url,
  jobTitle: SITE.authorRole,
  sameAs: [SOCIAL.github, SOCIAL.linkedin],
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Cochin University of Science and Technology",
  },
};
---

<BaseLayout
  title="About | Dani Issac"
  description="Dani Issac's background across enterprise networking, observability, technical learning, and practical network tooling."
  jsonLd={personSchema}
>
  <header class="page-hero shell reading-shell">
    <p class="eyebrow">About</p>
    <h1>Network engineering, practical education, and technical ownership.</h1>
    <p>
      My path runs from consulting engineer to network support to technical education and demonstration design. The
      connecting thread is practical: understand how a system behaves, make the evidence legible, and help someone
      act on it.
    </p>
    <div class="action-row">
      <a class="button button-primary" href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">
        LinkedIn <Linkedin size={17} aria-hidden="true" />
      </a>
      <a class="button button-secondary" href={SOCIAL.github} target="_blank" rel="noopener noreferrer">
        GitHub <Github size={17} aria-hidden="true" />
      </a>
    </div>
  </header>

  <section class="content-section">
    <div class="shell about-intro-grid">
      <div class="section-heading">
        <p class="eyebrow">The thread</p>
        <h2>From operating networks to teaching their behavior</h2>
      </div>
      <div class="about-copy">
        <p>
          Since 2019, I have worked across enterprise consulting, advanced network support, observability, and
          technical learning. That progression moved me closer to the work I care about most: translating telemetry,
          protocols, and implementation details into explanations and demonstrations people can use.
        </p>
        <p>
          Today I combine networking and observability expertise with technical writing, learning design, and small
          open-source projects. The aim is not to make the underlying systems look simple. It is to make their actual
          behavior easier to reason about.
        </p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Experience</p>
        <h2>Professional background</h2>
      </div>
      <div class="timeline">
        {EXPERIENCE.map((item) => (
          <article class="timeline-item">
            <div class="timeline-marker" aria-hidden="true"></div>
            <div class="timeline-content">
              <div class="timeline-heading">
                <div><h3>{item.role}</h3><p>{item.company}</p></div>
                <span>{item.period}</span>
              </div>
              <p>{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section focus-section">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Technical focus</p>
        <h2>The tools serve the diagnostic question</h2>
      </div>
      <div class="focus-grid">
        {TECHNICAL_FOCUS.map((group) => (
          <div class="focus-group">
            <h3>{group.label}</h3>
            <ul class="tag-list" aria-label={`${group.label} skills`}>
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Credentials</p>
        <h2>Selected certifications</h2>
      </div>
      <div class="cert-grid">
        {CERTIFICATIONS.map((certification) => (
          <a class="cert-card" href={certification.url} target="_blank" rel="noopener noreferrer">
            <span><strong>{certification.name}</strong><small>{certification.issuer}</small></span>
            <ExternalLink size={17} aria-hidden="true" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section education-section">
    <div class="shell about-intro-grid">
      <div class="section-heading">
        <p class="eyebrow">Education</p>
        <h2>Computer science foundation</h2>
      </div>
      <div class="education-record">
        <h3>Bachelor of Technology, Computer Science and Engineering</h3>
        <p>Cochin University of Science and Technology</p>
        <span>2015 - 2019</span>
      </div>
    </div>
  </section>

  <section class="closing-section shell">
    <p class="eyebrow">Connect</p>
    <h2>Follow the work as it develops.</h2>
    <p>New projects and shorter technical notes appear on GitHub and LinkedIn between longer articles.</p>
    <a class="button button-primary" href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">
      Connect on LinkedIn <ArrowUpRight size={17} aria-hidden="true" />
    </a>
  </section>
</BaseLayout>
